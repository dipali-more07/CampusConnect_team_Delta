# ============================================================
# CampusConnect - Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit your actual .env file to Git!
# ============================================================

# ---------- App Settings ----------
APP_NAME=CampusConnect
APP_VERSION=1.0.0
DEBUG=False
# The URL where your API will be available
APP_URL=http://localhost:8000

# ---------- Database ----------
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://campusconnect_user:your_password_here@localhost:5432/campusconnect_db

# ---------- JWT Authentication ----------
# SECRET_KEY: Used to sign JWT tokens. Must be long and random.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production
# Algorithm used to sign tokens
ALGORITHM=HS256
# How long access token lasts (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30
# How long refresh token lasts (in days)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- Email Settings ----------
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_email_app_password
MAIL_FROM=noreply@campusconnect.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# ---------- File Storage ----------
# Where uploaded files are stored
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ---------- Rate Limiting ----------
# Max requests per minute per IP
RATE_LIMIT_PER_MINUTE=60

# ---------- CORS (Cross-Origin Resource Sharing) ----------
# Domains allowed to call your API (your React/Next.js frontend URL)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:5173,http://127.0.0.1:8000,*

# ---------- First Admin User ----------
# This admin is created when the app starts for the first time
FIRST_ADMIN_EMAIL=admin@campusconnect.com
FIRST_ADMIN_PASSWORD=Admin@123456

# ---------- Razorpay ----------
# Get these keys from your Razorpay Dashboard (Settings -> API Keys)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Set to True to bypass Razorpay API/charges and run in mock payment mode
MOCK_PAYMENT=True
